# Copy this file to .env and fill in the values.
# The application reads these via os.Getenv with sensible defaults for local dev.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://showcase:showcase@localhost:5432/showcase?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
# If Redis requires a password, set it here:
# REDIS_PASSWORD=your-redis-password

# ── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANT: change this in production
JWT_SECRET=change-me-in-production

# ── OAuth2 ────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── OTel / Tracing ────────────────────────────────────────────────────────────
# Leave empty to disable OTLP export.
# With docker compose running: OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
# Set to any non-empty value to also print spans to stdout (dev only).
OTEL_STDOUT=

# ── Server addresses (cmd/grpc only) ─────────────────────────────────────────
HTTP_ADDR=:8081
GRPC_ADDR=:9091
